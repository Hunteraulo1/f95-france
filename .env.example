# URL publique du site (Open Graph, passkeys, security.txt)
PUBLIC_APP_ORIGIN="https://mon-site.site"

# Cloudflare Turnstile (captcha inscription + connexion après échec)
# https://dash.cloudflare.com/?to=/:account/turnstile
PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

NODE_ENV=production
APP_PORT=3000
TAILSCALE_IP=""

# Prod (Coolify) : obligatoire pour CSRF / actions formulaire (sinon 403 sur POST).
# PUBLIC_APP_ORIGIN suffit au démarrage (start → ORIGIN). Sinon définir ORIGIN explicitement.
# PUBLIC_APP_ORIGIN="https://ptb.f95france.site"

# Derrière reverse proxy (Coolify) : URL publique (adapter-node).
# PROTOCOL_HEADER=x-forwarded-proto
# HOST_HEADER=x-forwarded-host
#
# IP client : l’app lit x-real-ip / x-forwarded-for (1re IP = client) via client-address.ts.
# Optionnel — si tu laisses ADDRESS_HEADER=x-forwarded-for, la sonde /api/health ne doit pas crasher
# (géré dans le code). Évite XFF_DEPTH=1 seul : tu obtiens souvent 10.0.x.x (IP Docker).
# CLIENT_IP_XFF_STRATEGY=first   # défaut Coolify — client en tête de X-Forwarded-For
# CLIENT_IP_XFF_STRATEGY=kit     # même logique que adapter-node (XFF_DEPTH)
# ADDRESS_HEADER=x-forwarded-for
# XFF_DEPTH=2

# DATABASE
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
# Local (Docker) : pas de TLS. Postgres distant : POSTGRES_SSL_MODE=require
POSTGRES_SSL_MODE=disable

DATABASE_POOL_MAX=10

# Sync prod → dev / PTB (`bun run db:sync:prod-to-dev` | `db:sync:prod-to-ptb`)
# POSTGRES_PROD_* = source (prod). Cible dev : POSTGRES_DEV_* ou POSTGRES_* ci-dessus.
# Cible PTB : POSTGRES_PTB_* ou POSTGRES_* (souvent la même base que l’app sur Coolify).
# POSTGRES_PROD_HOST="10.x.x.x"
# POSTGRES_PROD_PORT=5432
# POSTGRES_PROD_DB=postgres
# POSTGRES_PROD_USER=postgres
# POSTGRES_PROD_PASSWORD=""
# POSTGRES_PROD_SSL_MODE=disable
# POSTGRES_PTB_HOST="10.x.x.x"
# POSTGRES_PTB_PASSWORD=""
#
# Coolify PTB uniquement : à chaque démarrage du conteneur (`bun run start`), recloner prod
# (public + drizzle.__drizzle_migrations). Ne pas définir sur la prod.
# SYNC_PROD_TO_PTB_ON_DEPLOY=true

# Contact divulgation responsable (RFC 9116 security.txt)
# SECURITY_CONTACT="mailto:security@mon-site.site"
# SECURITY_TXT_CANONICAL="https://mon-site.site/.well-known/security.txt"
# Clé OpenPGP (une ou les deux lignes Encryption: dans security.txt) :
# SECURITY_OPENPGP_FINGERPRINT="ABCD1234..."  # ou openpgp4fpr:ABCD1234...
# SECURITY_OPENPGP_KEY_URL="https://mon-site.site/.well-known/pgp-key.asc"

DISCORD_WEBHOOK_UPDATES=""
DISCORD_WEBHOOK_TRANSLATORS=""
DISCORD_WEBHOOK_ADMIN=""

DISCORD_OAUTH_CLIENT_ID=""
DISCORD_OAUTH_CLIENT_SECRET=""
# Redirect OAuth dans le portail Discord : https://votre-domaine/api/discord-oauth/callback
DISCORD_OAUTH_GUILD_ID=""
# ID du serveur Discord (snowflake). Requis pour la sync traducteur ; si invalide, la connexion fonctionne quand même.
DISCORD_OAUTH_TRANSLATOR_ROLE_ID=""
# Sync user ↔ translator à la liaison Discord selon le rôle serveur (true par défaut).
DISCORD_OAUTH_AUTO_ROLE_SYNC=true

# Inscription : REGISTRATION_DISABLED=true pour fermer ; REGISTRATION_INVITE_CODE pour exiger un code.
REGISTRATION_DISABLED=false
# REGISTRATION_INVITE_CODE=""

# Email (SMTP Proton Mail — vérification d’adresse à l’inscription)
# Proton : Paramètres → Proton Mail → IMAP/SMTP → Générer un token SMTP
# Port 587 (recommandé) : STARTTLS — ne pas mettre SMTP_SECURE=true
# Port 465 : TLS implicite — SMTP_SECURE=true (ou laisser vide, détecté auto)
# SMTP_HOST=smtp.protonmail.ch
# SMTP_PORT=587
# SMTP_USER="noreply@votre-domaine.com"
# SMTP_PASS=""  # token SMTP Proton (pas le mot de passe du compte)
# SMTP_FROM="F95 France <noreply@votre-domaine.com>"
# EMAIL_VERIFICATION_SKIP=true  # dev uniquement : désactive la vérification email

GOOGLE_API_KEY="" # Optionnel si OAuth connecté (Sheets)
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""
GOOGLE_SPREADSHEET_ID=""

# Traduction auto description_fr (défaut : MyMemory, gratuit, sans hébergement)
# TRANSLATION_PROVIDER=mymemory|google|off
TRANSLATION_PROVIDER=mymemory
# Optionnel : ~10 000 mots/jour au lieu de ~1 000 (email enregistré chez MyMemory)
# MYMEMORY_CONTACT_EMAIL=""

# Secret pour sécuriser /api/cron/check-version (POST ou GET).
# Envoyer via : Authorization: Bearer <CRON_SECRET> ou X-Cron-Secret: <CRON_SECRET>
# Générer avec : openssl rand -base64 32.
CRON_SECRET=""

# Coolify → Scheduled Tasks (ex. toutes les 6 h) :
#   node build/cron-check-version.mjs
# L’URL cible = CRON_BASE_URL, sinon PUBLIC_APP_ORIGIN (obligatoire en prod Coolify).

# Obligatoire en production : chiffre les jetons OAuth en base (32 octets en base64). Générer : openssl rand -base64 32
CONFIG_TOKEN_ENCRYPTION_KEY=""

# Optionnel : délai max d'attente HTTP (ms) avant réponse 202 "accepted" pour le cron.
# Min 1000, max 29000, défaut 25000.
# CRON_MAX_WAIT_MS=25000

# Optionnel : origines CORS pour /api/extract/f95|lc/[threadId], séparées par des virgules.
EXTRACT_F95_ALLOWED_ORIGINS="https://f95zone.to"
EXTRACT_LC_ALLOWED_ORIGINS="https://lewdcorner.com"
