# URL publique du site (Open Graph, passkeys, security.txt)
PUBLIC_APP_ORIGIN="https://mon-site.site"

# Cloudflare Turnstile (captcha inscription + connexion après échec)
# https://dash.cloudflare.com/?to=/:account/turnstile
PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

NODE_ENV=production
APP_PORT=3000
TAILSCALE_IP=""

# Derrière reverse proxy (Coolify) : adapter-node utilise X-Forwarded-Proto pour l’URL publique.
# PROTOCOL_HEADER=x-forwarded-proto
# HOST_HEADER=x-forwarded-host

# DATABASE
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
# Local (Docker) : pas de TLS. Postgres distant : POSTGRES_SSL_MODE=require
POSTGRES_SSL_MODE=disable

DATABASE_POOL_MAX=10

# Sync prod → dev (`bun run db:sync:prod-to-dev`) — prod distante, dev = POSTGRES_* ci-dessus
# POSTGRES_PROD_HOST="10.x.x.x"
# POSTGRES_PROD_PORT=5432
# POSTGRES_PROD_DB=postgres
# POSTGRES_PROD_USER=postgres
# POSTGRES_PROD_PASSWORD=""
# POSTGRES_PROD_SSL_MODE=disable
# Optionnel : POSTGRES_DEV_* pour une cible différente de POSTGRES_*

# Contact divulgation responsable (RFC 9116 security.txt)
# SECURITY_CONTACT="mailto:security@mon-site.site"
# SECURITY_TXT_CANONICAL="https://mon-site.site/.well-known/security.txt"

DISCORD_WEBHOOK_UPDATES=""
DISCORD_WEBHOOK_TRANSLATORS=""
DISCORD_WEBHOOK_ADMIN=""

DISCORD_OAUTH_CLIENT_ID=""
DISCORD_OAUTH_CLIENT_SECRET=""
DISCORD_OAUTH_GUILD_ID=""
DISCORD_OAUTH_TRANSLATOR_ROLE_ID=""
# Sync user ↔ translator à la liaison Discord selon le rôle serveur (true par défaut).
DISCORD_OAUTH_AUTO_ROLE_SYNC=true

# Inscription : REGISTRATION_DISABLED=true pour fermer ; REGISTRATION_INVITE_CODE pour exiger un code.
REGISTRATION_DISABLED=false
# REGISTRATION_INVITE_CODE=""

GOOGLE_API_KEY="" # Optionnel, si OAuth2
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""
GOOGLE_SPREADSHEET_ID=""

# Secret pour sécuriser /api/cron/check-version (POST ou GET).
# Envoyer via : Authorization: Bearer <CRON_SECRET> ou X-Cron-Secret: <CRON_SECRET>
# Générer avec : openssl rand -base64 32.
CRON_SECRET=""

# Sonde /api/health en production (Bearer ou X-Health-Token). Sinon CRON_SECRET est accepté.
# HEALTH_CHECK_TOKEN=""

# Coolify → Scheduled Tasks (ex. toutes les 6 h) :
#   node build/cron-check-version.mjs
# L’URL cible = CRON_BASE_URL, sinon PUBLIC_APP_ORIGIN (obligatoire en prod Coolify).

# Obligatoire en production : chiffre les jetons OAuth en base (32 octets en base64). Générer : openssl rand -base64 32
CONFIG_TOKEN_ENCRYPTION_KEY=""

# Optionnel : délai max d'attente HTTP (ms) avant réponse 202 "accepted" pour le cron.
# Min 1000, max 29000, défaut 25000.
# CRON_MAX_WAIT_MS=25000

# Optionnel : origines CORS pour /api/extract/f95|lc/[threadId], séparées par des virgules.
EXTRACT_F95_ALLOWED_ORIGINS="https://f95zone.to"
EXTRACT_LC_ALLOWED_ORIGINS="https://lewdcorner.com"
