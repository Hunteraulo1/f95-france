DATABASE_URL="postgres:postgres@supabase_db_"

# DATABASE
TAILSCALE_IP=""
POSTGRES_PORT=5432
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=

NODE_ENV=production

# URL publique du site (Open Graph, passkeys, security.txt)
# PUBLIC_APP_ORIGIN="https://f95france.site"

# Contact divulgation responsable (RFC 9116 security.txt)
# SECURITY_CONTACT="mailto:security@f95france.site"
# SECURITY_TXT_CANONICAL="https://f95france.site/.well-known/security.txt"

DISCORD_WEBHOOK_UPDATES=""
DISCORD_WEBHOOK_TRANSLATORS=""
DISCORD_WEBHOOK_PROOFREADERS=""
DISCORD_WEBHOOK_LOGS=""

DISCORD_OAUTH_CLIENT_ID=""
DISCORD_OAUTH_CLIENT_SECRET=""
DISCORD_OAUTH_GUILD_ID=""
DISCORD_OAUTH_TRANSLATOR_ROLE_ID=""

GOOGLE_API_KEY="" # Optionnel, si OAuth2
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""
GOOGLE_SPREADSHEET_ID=""

# Secret pour sécuriser POST /api/cron/check-version (header Authorization: Bearer …).
# Générer avec : openssl rand -base64 32.
CRON_SECRET=""

# Optionnel : si défini, le User-Agent doit contenir cette chaîne.
# CRON_ALLOWED_USER_AGENT=""

# Optionnel : délai max d'attente HTTP (ms) avant réponse 202 "accepted" pour le cron.
# Min 1000, max 29000, défaut 25000.
# CRON_MAX_WAIT_MS=25000

# Optionnel : exécution forcée en ignorant le slot via query param `?force=1` (auth CRON requise).
# Exemple manuel : POST /api/cron/check-version?force=1

# Optionnel : chiffre les jetons OAuth en base (32 octets en base64). Générer : openssl rand -base64 32
CONFIG_TOKEN_ENCRYPTION_KEY=""

# Optionnel : origines CORS pour /api/extract/f95|lc/[threadId], séparées par des virgules.
# EXTRACT_F95_ALLOWED_ORIGINS="https://f95zone.to"
# EXTRACT_LC_ALLOWED_ORIGINS="https://lewdcorner.com"
