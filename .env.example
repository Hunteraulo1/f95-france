# Template complet des variables d'environnement.
#
# Dev local  → copier en .env      (chargé par vite dev + docker-compose.dev.yml)
# Prod Docker → copier en .env.prod (chargé par docker-compose.yml)
#
# Les deux fichiers sont gitignorés. Seul .env.example est commité.

# ─── App ─────────────────────────────────────────────────────────────────────
# dev: NODE_ENV=development | prod: fixé dans docker-compose.yml (production)
NODE_ENV=development
HOST=0.0.0.0
APP_PORT=3000

# prod uniquement : IP Tailscale pour le binding du port MariaDB
# dev : 127.0.0.1
TAILSCALE_IP=127.0.0.1

# URL publique du site (Open Graph, passkeys, security.txt)
PUBLIC_APP_ORIGIN="https://mon-site.site"

# Cloudflare Turnstile (captcha inscription + connexion après échec)
# https://dash.cloudflare.com/?to=/:account/turnstile
# PUBLIC_TURNSTILE_SITE_KEY=""
# TURNSTILE_SECRET_KEY=""

# Derrière reverse proxy — prod uniquement (Traefik/Caddy/Coolify)
# PROTOCOL_HEADER=x-forwarded-proto
# HOST_HEADER=x-forwarded-host
# ADDRESS_HEADER=x-forwarded-for
# CLIENT_IP_XFF_STRATEGY=first

# ─── Sync postgres → dev (`bun run db:migrate:from-postgres`) ────────────────────
PG_HOST=""
PG_PORT=5432
PG_DATABASE=""
PG_USER=""
PG_PASSWORD=""
PG_SSL_MODE=""

TO_MARIADB_HOST=""
TO_MARIADB_PORT=3306
TO_MARIADB_DATABASE=""
TO_MARIADB_USER=""
TO_MARIADB_PASSWORD=""
TO_MARIADB_SSL_MODE=""

# ─── Base de données (MariaDB) ────────────────────────────────────────────────
# dev : MARIADB_HOST=localhost | prod : fixé dans docker-compose.yml (service mariadb)
MARIADB_HOST=localhost
MARIADB_PORT=3306
MARIADB_DATABASE=f95france
MARIADB_USER=f95france
MARIADB_PASSWORD=
MARIADB_ROOT_PASSWORD=
# SSL : disable (local/Docker), require (MariaDB distant)
# MARIADB_SSL_MODE=disable
DATABASE_POOL_MAX=10

# Sync prod → dev (`bun run db:sync:prod-to-dev`)
# MARIADB_PROD_HOST=""
# MARIADB_PROD_PORT=3306
# MARIADB_PROD_DATABASE=""
# MARIADB_PROD_USER=""
# MARIADB_PROD_PASSWORD=""

# Sync prod → PTB (prod uniquement, ressource PTB)
# MARIADB_PTB_HOST=""
# MARIADB_PTB_PASSWORD=""
# SYNC_PROD_TO_PTB_ON_DEPLOY=true

# ─── Sécurité (RFC 9116 security.txt) ────────────────────────────────────────
# SECURITY_CONTACT="mailto:security@mon-site.site"
# SECURITY_TXT_CANONICAL="https://mon-site.site/.well-known/security.txt"
# SECURITY_OPENPGP_FINGERPRINT="ABCD1234..."
# SECURITY_OPENPGP_KEY_URL="https://mon-site.site/.well-known/pgp-key.asc"

# ─── Discord ─────────────────────────────────────────────────────────────────
DISCORD_WEBHOOK_UPDATES=""
DISCORD_WEBHOOK_TRANSLATORS=""
DISCORD_WEBHOOK_ADMIN=""

DISCORD_OAUTH_CLIENT_ID=""
DISCORD_OAUTH_CLIENT_SECRET=""
# Redirect OAuth dans le portail Discord : https://votre-domaine/api/discord-oauth/callback
DISCORD_OAUTH_GUILD_ID=""
DISCORD_OAUTH_TRANSLATOR_ROLE_ID=""
DISCORD_OAUTH_AUTO_ROLE_SYNC=true

# ─── Inscription ─────────────────────────────────────────────────────────────
REGISTRATION_DISABLED=false
# REGISTRATION_INVITE_CODE=""

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
# dev : EMAIL_VERIFICATION_SKIP=true pour ne pas envoyer d'emails réels
# EMAIL_VERIFICATION_SKIP=true
# Proton : Paramètres → Proton Mail → IMAP/SMTP → Générer un token SMTP
# Port 587 (STARTTLS) ou 465 (TLS implicite, SMTP_SECURE=true)
# SMTP_HOST=smtp.protonmail.ch
# SMTP_PORT=587
# SMTP_USER="noreply@votre-domaine.com"
# SMTP_PASS=""
# SMTP_FROM="F95 France <noreply@votre-domaine.com>"

# ─── Google ──────────────────────────────────────────────────────────────────
GOOGLE_API_KEY=""
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""
GOOGLE_SPREADSHEET_ID=""

# ─── LibreTranslate ──────────────────────────────────────────────────────────
LIBRETRANSLATE_URL=https://translate.f95france.site
# LIBRETRANSLATE_API_KEY=""
# DESCRIPTION_AUTO_TRANSLATE=false

# ─── Cron ────────────────────────────────────────────────────────────────────
# Secret pour sécuriser /api/cron/check-version
# Générer : openssl rand -base64 32
CRON_SECRET=""
# CRON_MAX_WAIT_MS=25000

# ─── Chiffrement tokens OAuth ────────────────────────────────────────────────
# Obligatoire en production — Générer : openssl rand -base64 32
CONFIG_TOKEN_ENCRYPTION_KEY=""

# ─── CORS extract ────────────────────────────────────────────────────────────
EXTRACT_F95_ALLOWED_ORIGINS="https://f95zone.to"
EXTRACT_LC_ALLOWED_ORIGINS="https://lewdcorner.com"
