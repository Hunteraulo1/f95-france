{
	"name": "f95-france",
	"private": true,
	"version": "4.11.2",
	"type": "module",
	"engines": {
		"node": ">=24.0.0"
	},
	"scripts": {
		"dev": "vite dev",
		"dev:fresh": "rm -rf node_modules/.vite .svelte-kit && svelte-kit sync && vite dev --force",
		"dev:up": "docker compose -f docker-compose.dev.yml up -d mariadb-dev",
		"dev:down": "docker compose -f docker-compose.dev.yml down",
		"dev:logs": "docker compose -f docker-compose.dev.yml logs -f mariadb-dev",
		"build": "NODE_ENV=production vite build && cp cron/check-version.mjs build/cron-check-version.mjs",
		"build:docker": "docker compose -f docker-compose.dev.yml --profile full up --build",
		"start": "bash scripts/coolify-start.sh",
		"preview": "ORIGIN=http://localhost:4173 PORT=4173 HOST=0.0.0.0 node --env-file=.env build/index.js",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --write . && eslint .",
		"db:push": "drizzle-kit push",
		"db:pull": "drizzle-kit pull",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "bun src/lib/server/db/migrate.ts",
		"db:stamp-migrations": "bun src/lib/server/db/stamp-migrations-from-journal.ts",
		"db:studio": "drizzle-kit studio",
		"db:sync:prod-to-dev": "bash scripts/sync-db.sh --target dev",
		"db:sync:prod-to-ptb": "bash scripts/sync-db.sh --target ptb",
		"db:migrate:from-postgres": "bun scripts/migrate-postgres-to-mariadb.ts",
		"cron:check-version": "node cron/check-version.mjs",
		"sheet:diff-jeux": "bun scripts/compare-jeux-csv.ts"
	},
	"devDependencies": {
		"@eslint/js": "10.0.1",
		"@sveltejs/vite-plugin-svelte": "7.2.0",
		"@types/node": "26.1.1",
		"@types/nodemailer": "8.0.1",
		"@types/qrcode": "1.5.6",
		"chrome-launcher": "1.2.1",
		"commitizen": "4.3.2",
		"cz-emoji": "1.3.2-canary.2",
		"eslint": "10.7.0",
		"eslint-config-prettier": "10.1.8",
		"eslint-plugin-svelte": "3.20.0",
		"globals": "17.7.0",
		"pg": "8.22.0",
		"prettier": "3.9.5",
		"prettier-plugin-svelte": "4.1.1",
		"prettier-plugin-tailwindcss": "0.8.1",
		"svelte": "5.56.5",
		"svelte-check": "4.7.3",
		"tailwindcss": "4.3.3",
		"typescript": "^6.0.3",
		"typescript-eslint": "8.64.0"
	},
	"dependencies": {
		"@codemirror/lang-markdown": "6.5.1",
		"@lucide/svelte": "1.24.0",
		"@oslojs/crypto": "1.0.1",
		"@oslojs/encoding": "1.1.0",
		"@simplewebauthn/browser": "13.3.0",
		"@simplewebauthn/server": "13.3.2",
		"@sveltejs/adapter-node": "5.5.7",
		"@sveltejs/kit": "2.69.3",
		"@tailwindcss/forms": "0.5.11",
		"@tailwindcss/vite": "4.3.3",
		"codemirror": "6.0.2",
		"daisyui": "5.6.18",
		"dotenv": "17.4.2",
		"drizzle-kit": "0.31.10",
		"drizzle-orm": "0.45.2",
		"linkedom": "0.18.13",
		"marked": "18.0.6",
		"mysql2": "3.23.0",
		"nodemailer": "9.0.3",
		"otpauth": "9.5.1",
		"qrcode": "1.5.4",
		"svelte-codemirror-editor": "2.1.0",
		"valibot": "1.4.2",
		"vite": "8.1.5"
	},
	"overrides": {
		"typescript": "~6"
	},
	"config": {
		"commitizen": {
			"path": "cz-emoji"
		},
		"cz-emoji": {
			"scopes": [
				"backend",
				"frontend"
			],
			"skipQuestions": [
				"body",
				"breaking"
			]
		}
	},
	"trustedDependencies": [
		"core-js",
		"esbuild"
	]
}
