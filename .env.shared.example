# ════════════════════════════════════════════════════════════════════════════
# Coolify › Project › Shared Variables — template
# Copier dans .env.shared et remplir les valeurs manquantes.
#
# ════════════════════════════════════════════════════════════════════════════

# ─── Sécurité (RFC 9116) ─────────────────────────────────────────────────────
SECURITY_CONTACT="mailto:security@mon-site.site"
SECURITY_TXT_CANONICAL="https://mon-site.site/.well-known/security.txt"
# SECURITY_OPENPGP_FINGERPRINT=""
# SECURITY_OPENPGP_KEY_URL=""

# ─── Discord ─────────────────────────────────────────────────────────────────
# DISCORD_OAUTH_CLIENT_ID=""
# DISCORD_OAUTH_CLIENT_SECRET=""DISCORD_OAUTH_GUILD_ID=""
# DISCORD_OAUTH_TRANSLATOR_ROLE_ID=""
DISCORD_OAUTH_AUTO_ROLE_SYNC=false

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
# Port 587 (STARTTLS recommandé) ou 465 (TLS implicite)
# SMTP_HOST=smtp.protonmail.ch
# SMTP_PORT=587
# SMTP_USER=""
# SMTP_PASS=""
# SMTP_FROM=""

# ─── Google ──────────────────────────────────────────────────────────────────
# GOOGLE_API_KEY=""
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""

# ─── LibreTranslate ──────────────────────────────────────────────────────────
# LIBRETRANSLATE_URL=https://translate.f95france.site
# LIBRETRANSLATE_API_KEY=""

# ─── Chiffrement tokens OAuth ────────────────────────────────────────────────
# Générer : openssl rand -base64 32
CONFIG_TOKEN_ENCRYPTION_KEY=""

# ─── Cloudflare Turnstile ────────────────────────────────────────────────────
# PUBLIC_TURNSTILE_SITE_KEY=""
# TURNSTILE_SECRET_KEY=""
