# ════════════════════════════════════════════════════════════════════════════
# PTB — Coolify › Environment Variables — template
# Copier dans .env.ptb et remplir les valeurs manquantes.
# Les vars {{project.*}} viennent des Shared Variables du projet.
# ════════════════════════════════════════════════════════════════════════════

PUBLIC_APP_ORIGIN="https://ptb.mon-site.site"
APP_PORT={{project.APP_PORT}}
GOOGLE_SPREADSHEET_ID=""

PROTOCOL_HEADER={{project.PROTOCOL_HEADER}}
HOST_HEADER={{project.HOST_HEADER}}

# ─── Base de données PTB ─────────────────────────────────────────────────────
# MARIADB_HOST = nom du container MariaDB PTB (`docker ps` sur le serveur Coolify)
MARIADB_HOST=<nom-container-mariadb-ptb>
MARIADB_PORT={{project.MARIADB_PORT}}
MARIADB_DATABASE=
MARIADB_USER=
MARIADB_PASSWORD=""
MARIADB_SSL_MODE={{project.MARIADB_SSL_MODE}}
DATABASE_POOL_MAX={{project.DATABASE_POOL_MAX}}

# ─── Sync prod → PTB au démarrage ────────────────────────────────────────────
SYNC_PROD_TO_PTB_ON_DEPLOY=true
MARIADB_PROD_HOST=<nom-container-mariadb-prod>
MARIADB_PROD_PORT={{project.MARIADB_PORT}}
MARIADB_PROD_DATABASE=
MARIADB_PROD_USER=
MARIADB_PROD_PASSWORD=""

# ─── PTB uniquement ──────────────────────────────────────────────────────────
REGISTRATION_INVITE_CODE=""

# ─── Shared ──────────────────────────────────────────────────────────────────
SECURITY_CONTACT={{project.SECURITY_CONTACT}}
SECURITY_TXT_CANONICAL={{project.SECURITY_TXT_CANONICAL}}
SECURITY_OPENPGP_FINGERPRINT={{project.SECURITY_OPENPGP_FINGERPRINT}}
SECURITY_OPENPGP_KEY_URL={{project.SECURITY_OPENPGP_KEY_URL}}

DISCORD_WEBHOOK_UPDATES={{project.DISCORD_WEBHOOK_UPDATES}}
DISCORD_WEBHOOK_TRANSLATORS={{project.DISCORD_WEBHOOK_TRANSLATORS}}
DISCORD_WEBHOOK_ADMIN={{project.DISCORD_WEBHOOK_ADMIN}}
DISCORD_OAUTH_CLIENT_ID={{project.DISCORD_OAUTH_CLIENT_ID}}
DISCORD_OAUTH_CLIENT_SECRET={{project.DISCORD_OAUTH_CLIENT_SECRET}}
DISCORD_OAUTH_GUILD_ID={{project.DISCORD_OAUTH_GUILD_ID}}
DISCORD_OAUTH_TRANSLATOR_ROLE_ID={{project.DISCORD_OAUTH_TRANSLATOR_ROLE_ID}}
DISCORD_OAUTH_AUTO_ROLE_SYNC={{project.DISCORD_OAUTH_AUTO_ROLE_SYNC}}

REGISTRATION_DISABLED={{project.REGISTRATION_DISABLED}}

SMTP_HOST={{project.SMTP_HOST}}
SMTP_PORT={{project.SMTP_PORT}}
SMTP_USER={{project.SMTP_USER}}
SMTP_PASS={{project.SMTP_PASS}}
SMTP_FROM={{project.SMTP_FROM}}

GOOGLE_API_KEY={{project.GOOGLE_API_KEY}}
GOOGLE_OAUTH_CLIENT_ID={{project.GOOGLE_OAUTH_CLIENT_ID}}
GOOGLE_OAUTH_CLIENT_SECRET={{project.GOOGLE_OAUTH_CLIENT_SECRET}}

LIBRETRANSLATE_URL={{project.LIBRETRANSLATE_URL}}
LIBRETRANSLATE_API_KEY={{project.LIBRETRANSLATE_API_KEY}}

CRON_SECRET={{project.CRON_SECRET}}
CONFIG_TOKEN_ENCRYPTION_KEY={{project.CONFIG_TOKEN_ENCRYPTION_KEY}}

EXTRACT_F95_ALLOWED_ORIGINS={{project.EXTRACT_F95_ALLOWED_ORIGINS}}
EXTRACT_LC_ALLOWED_ORIGINS={{project.EXTRACT_LC_ALLOWED_ORIGINS}}
